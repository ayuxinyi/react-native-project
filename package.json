{
  "name": "react-native-project",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.5",
      "@better-auth/expo": "1.5.5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @react-native-project/db db:push",
    "db:studio": "turbo -F @react-native-project/db db:studio",
    "db:generate": "turbo -F @react-native-project/db db:generate",
    "db:migrate": "turbo -F @react-native-project/db db:migrate"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@react-native-project/env": "workspace:*",
    "dotenv": "catalog:",
    "eslint": "^10.1.0",
    "eslint-config-expo": "^55.0.0",
    "typescript-eslint": "^8.58.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@react-native-project/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
