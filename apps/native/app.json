{
  "expo": {
    "scheme": "react-native-project",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "bundler": "metro"
    },
    "name": "react-native-project",
    "slug": "react-native-project",
    "plugins": [
      "expo-font",
      "expo-image",
      "expo-router",
      "expo-secure-store",
      "expo-sharing",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
