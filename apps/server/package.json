{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/types.ts",
  "exports": {
    ".": {
      "types": "./src/types.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@react-native-project/auth": "workspace:*",
    "@react-native-project/db": "workspace:*",
    "@react-native-project/env": "workspace:*",
    "@react-native-project/schema": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@react-native-project/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "catalog:"
  },
  "trustedDependencies": [
    "supabase"
  ]
}
